PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup.html
# Optional — food search falls back to OpenFoodFacts + seed DB when unset.
USDA_API_KEY=

# Google Gemini API key (BYOK) for the AI coach: https://aistudio.google.com/apikey
# Optional — coach features are disabled when unset.
GEMINI_API_KEY=
